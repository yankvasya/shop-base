# Shopify Storefront API (public, publishable token — safe for client-side use)
NUXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NUXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-api-token
NUXT_PUBLIC_SHOPIFY_API_VERSION=2025-10

# Absolute, HTTPS, no trailing slash — must match a callback URL registered
# with the Customer Account API (see README). Shopify does not allow
# http:// or localhost callback URLs, so local dev needs a tunnel
# (ngrok/cloudflared) pointed at this same URL.
NUXT_PUBLIC_SITE_URL=https://your-deployed-domain.example.com

# Customer Account API (confidential client) — server-only, never expose
# these with a NUXT_PUBLIC_ prefix.
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=your-customer-account-client-id
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET=your-customer-account-client-secret

# Random 32+ character string used to seal the customer session cookie.
# Generate one with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=change-me-to-a-random-32-character-string
